---
export interface Props {
  startDate: string
  yearText: string
  yearsText: string
  monthText: string
  monthsText: string
}

const { startDate, yearText, yearsText, monthText, monthsText } = Astro.props

function getElapsedMonths(start: Date, end: Date) {
  const months =
    (end.getUTCFullYear() - start.getUTCFullYear()) * 12 +
    (end.getUTCMonth() - start.getUTCMonth()) -
    (end.getUTCDate() < start.getUTCDate() ? 1 : 0)

  return Math.max(months, 0)
}

function formatDurationSince(start: Date, end = new Date(Date.now())) {
  const totalMonths = getElapsedMonths(start, end)
  const years = Math.floor(totalMonths / 12)
  const months = totalMonths % 12
  const parts: string[] = []

  if (years > 0) {
    parts.push(`${years} ${years === 1 ? yearText : yearsText}`)
  }

  if (months > 0) {
    parts.push(`${months} ${months === 1 ? monthText : monthsText}`)
  }

  return `+${parts.join(' ') || `0 ${monthsText}`}`
}
---

{formatDurationSince(new Date(startDate))}
